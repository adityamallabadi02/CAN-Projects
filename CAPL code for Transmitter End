variables
{
   message 0x500 msg; //we can use the msg name eng or 0x500
   mstimer t1;
   int spd = 0;
}

on start 
{
	msg.dlc = 8;
	setTimer(t1,100);  
}
on timer t1
{
	output(msg);
	setTimer(t1,100); 
}

on message 0x400  //name it msg name or msg I'd
{
    spd = this.byte(0)*100;

	msg.byte(0) = spd & 0xFF;
	msg.byte(1) = (spd >> 8);

}
